{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "语枢",
  "version": "0.1.0",
  "identifier": "com.voicehub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "语枢",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
